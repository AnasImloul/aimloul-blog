vars: {
d2-config: {
layout-engine: elk
}
}

direction: down

# Root node
root: {
  label: "Root\n| 300 | 700 |"
  shape: rectangle
  style: {
  fill: "#1e293b"
  stroke: "#3b82f6"
  stroke-width: 2
  font-color: "#f1f5f9"
  bold: true
  border-radius: 4
  }
}

# Internal nodes (level 2)
int1: {
  label: "Internal\n| 100 | 200 |"
