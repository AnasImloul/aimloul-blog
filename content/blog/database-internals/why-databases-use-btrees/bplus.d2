vars: {
  d2-config: {
    layout-engine: elk
  }
}

direction: down

root: "Root\n| 300 | 700 |"

int1: "Internal\n| 100 | 200 |\n"
int2: "Internal\n| 400 | 600 |\n"
int3: "Internal\n| 800 | 900 |\n"

leaf1: "Leaf" {
  shape: sql_table
  50: row_data
  80: row_data
}
leaf2: "Leaf" {
  shape: sql_table
  110: row_data
  160: row_data
}
leaf3: "Leaf" {
  shape: sql_table
  210: row_data
  260: row_data
}
leaf4: "Leaf" {
  shape: sql_table
  310: row_data
  380: row_data
}
leaf5: "Leaf" {
  shape: sql_table
  410: row_data
  560: row_data
}
leaf6: "Leaf" {
  shape: sql_table
  610: row_data
  680: row_data
}
leaf7: "Leaf" {
  shape: sql_table
  710: row_data
  780: row_data
}
leaf8: "Leaf" {
  shape: sql_table
  810: row_data
  880: row_data
}
leaf9: "Leaf" {
  shape: sql_table
  910: row_data
  980: row_data
}

spine: {
  label: "← sequential scan →"
  shape: rectangle
  style: {
    stroke-dash: 4
    font-size: 12
    italic: true
  }
}

root -> int1
root -> int2
root -> int3

int1 -> leaf1
int1 -> leaf2
int1 -> leaf3

int2 -> leaf4
int2 -> leaf5
int2 -> leaf6

int3 -> leaf7
int3 -> leaf8
int3 -> leaf9

leaf1 -> spine: {
  style: {
    stroke: "transparent"
    stroke-width: 0
  }
}

leaf9 -> spine: {
  style: {
    stroke: "transparent"
    stroke-width: 0
  }
}
